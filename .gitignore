# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
.eggs/

# ── Virtual environments ───────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.local
.env.*.local

# ── uv ────────────────────────────────────────────────────────────
# Keep uv.lock committed (reproducible installs), but ignore scratch
.uv/

# ── Secrets / credentials ─────────────────────────────────────────
.env
*.secret
secrets.json
hf_token.txt

# ── IDE / Editor ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Graphify (large cache — never commit) ─────────────────────────
graphify-out/cache/
graphify-out/logs/

# ── Test / evaluation outputs ─────────────────────────────────────
outputs/
results/
*.log
*.csv
*.jsonl

# ── Docker ────────────────────────────────────────────────────────
.dockerignore

# ── Temporary reference copy (large) ─────────────────────────────
tmp_reference/

# ── Misc ──────────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
patch_scenarios.py
